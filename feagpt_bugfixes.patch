diff --git a/feagpt/meshing/mesher.py b/feagpt/meshing/mesher.py
index 6934839..2b9b13b 100644
--- a/feagpt/meshing/mesher.py
+++ b/feagpt/meshing/mesher.py
@@ -79,11 +79,85 @@ class AdaptiveMesher:
 
         # Export to CalculiX INP format
         gmsh.write(str(output_path))
+
+        # simulator.generate_input_deck() emits *BOUNDARY/*CLOAD cards that
+        # reference literal node sets NFIX/NLOAD -- these are never produced
+        # by gmsh's own Abaqus/CalculiX export (which only writes ELSETs for
+        # surface physical groups, not node sets), so without this the deck
+        # references undefined sets and CalculiX refuses to run.
+        self._write_bc_load_nsets(spec, output_path)
+
         gmsh.clear()
 
         logger.info(f"Mesh saved: {output_path}")
         return output_path
 
+    def _write_bc_load_nsets(self, spec: Dict, mesh_path: Path):
+        """
+        Identify the fixed-end and free-end faces by geometric extent (min/max
+        X of the model bounding box) and append CalculiX *NSET definitions:
+        NFIX (all nodes on the fixed face, a proper root constraint) and
+        NLOAD (the single node nearest the free face's centroid, so
+        generate_input_deck's *CLOAD applies the full magnitude once rather
+        than once per node in the set).
+        """
+        gmsh = self._gmsh
+        bcs = spec.get("boundary_conditions", [])
+        loads = spec.get("loads", [])
+        if not bcs or not loads:
+            return
+
+        xmin, ymin, zmin, xmax, ymax, zmax = gmsh.model.getBoundingBox(-1, -1)
+        tol = 1e-6 * max(xmax - xmin, 1.0)
+
+        fixed_face = None
+        free_face = None
+        for dim, tag in gmsh.model.occ.getEntities(2):
+            sxmin, symin, szmin, sxmax, symax, szmax = gmsh.model.getBoundingBox(dim, tag)
+            if abs(sxmin - xmin) < tol and abs(sxmax - xmin) < tol:
+                fixed_face = tag
+            if abs(sxmin - xmax) < tol and abs(sxmax - xmax) < tol:
+                free_face = tag
+
+        if fixed_face is None or free_face is None:
+            logger.warning(
+                "Could not identify fixed/free end faces by geometry; "
+                "NFIX/NLOAD node sets not written."
+            )
+            return
+
+        fix_node_tags, _, _ = gmsh.model.mesh.getNodes(2, fixed_face, includeBoundary=True)
+
+        load_node_tags, load_coords, _ = gmsh.model.mesh.getNodes(2, free_face, includeBoundary=True)
+        cy = (ymin + ymax) / 2.0
+        cz = (zmin + zmax) / 2.0
+        best_tag, best_dist = None, None
+        for i, tag in enumerate(load_node_tags):
+            y = load_coords[3 * i + 1]
+            z = load_coords[3 * i + 2]
+            d = (y - cy) ** 2 + (z - cz) ** 2
+            if best_dist is None or d < best_dist:
+                best_dist, best_tag = d, tag
+
+        def _nset_block(name, tags):
+            lines = [f"*NSET, NSET={name}"]
+            tags = [int(t) for t in tags]
+            for i in range(0, len(tags), 8):
+                lines.append(", ".join(str(t) for t in tags[i:i + 8]))
+            return "\n".join(lines)
+
+        with open(mesh_path, "a") as f:
+            f.write("\n")
+            f.write(_nset_block("NFIX", fix_node_tags))
+            f.write("\n")
+            f.write(_nset_block("NLOAD", [best_tag]))
+            f.write("\n")
+
+        logger.info(
+            f"NFIX: {len(fix_node_tags)} nodes on fixed face (tag {fixed_face}); "
+            f"NLOAD: node {best_tag} on free face (tag {free_face})"
+        )
+
     def _apply_refinement(self, zones: List[str], hmin: float, hmax: float):
         gmsh = self._gmsh
         if not zones:
@@ -131,16 +205,14 @@ class AdaptiveMesher:
